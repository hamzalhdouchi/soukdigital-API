# ── Database ────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/soukdigital
DB_USER=postgres
DB_PASSWORD=your_password

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your-super-secret-key-minimum-256-bits-long-please-change-this

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Mail (Resend) ────────────────────────────
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=re_xxxxxxxxxxxx

# ── SMS (Infobip) ────────────────────────────
INFOBIP_BASE_URL=https://xxxxx.api.infobip.com
INFOBIP_API_KEY=your_infobip_api_key
INFOBIP_SENDER=SoukDigital

# ── Storage (MinIO) ──────────────────────────
STORAGE_BUCKET=product-photo
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_PUBLIC_URL=http://localhost:9000/product-photo

# ── CMI Payment ──────────────────────────────
CMI_MERCHANT_ID=your_merchant_id
CMI_STORE_KEY=your_store_key
CMI_GATEWAY_URL=https://testpayment.cmi.co.ma/fim/est3Dgate
CMI_OK_URL=http://localhost:3000/checkout/success
CMI_FAIL_URL=http://localhost:3000/checkout/failed
CMI_CALLBACK_URL=https://your-api.railway.app/api/payment/cmi/callback
